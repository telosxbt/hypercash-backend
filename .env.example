# HyperEVM JSON-RPC (eth_getLogs capped at 1000-block range)
RPC_URL=https://hyperliquid-testnet.g.alchemy.com/v2/XXXX
# Postgres (Railway provides DATABASE_URL automatically when you attach a PG plugin)
DATABASE_URL=postgres://user:pass@host:5432/railway
# Pools to index: JSON array of { address, deployBlock, label } (v1 testnet, see deployments/v1-testnet.json)
POOLS=[{"address":"0xd0565a92ff225f5bbaf1fc91d6450072e159c656","deployBlock":57120943,"label":"usdc"},{"address":"0x04ec02cef83a22431bc329540a973c3582b472fa","deployBlock":57120943,"label":"hype"},{"address":"0x08f4697541ba34ac20ea9b82b72a2c4c7692a1f7","deployBlock":57120943,"label":"btc"},{"address":"0x9abfd0a850998492425ac0b06558b5913e0a1eea","deployBlock":57120943,"label":"eth"}]
# Tuning
CONFIRMATIONS=5
POLL_INTERVAL_MS=4000
LOG_CHUNK=999
BACKFILL_CONCURRENCY=10
PORT=3000
CORS_ORIGIN=*
# Tests only: a throwaway Postgres for `bun test`
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5544/postgres

# --- Optional v1 relayer (/relay/*) — only enabled if RELAYER_PRIVATE_KEY set ---
# RELAYER_PRIVATE_KEY=0x...        # funded with HYPE for gas (signs trade + deliver/cancel)
# CHAIN_ID=998
# TRADER_ADDRESS=0x5645f1d1933b7c3e8e481df31a4c7329ee26db83
# USDC_POOL_ADDRESS=0xd0565a92ff225f5bbaf1fc91d6450072e159c656
# HYPE_POOL_ADDRESS=0x04ec02cef83a22431bc329540a973c3582b472fa
# CORE_GATEWAY=0x5bc2b726f97792c9d8cf46420e42694022f46055   # optional; else read via trader.core()
# MIN_FEE_USDC=0                   # must cover gas of trade() + deliver()/cancel()
# MIN_FEE_HYPE=0
# MIN_FEE_DEPOSIT=0                # gasless USDC deposit (/relay/deposit); 0 = relayer eats gas (onboarding)
# GAS_TRADE=2500000
# GAS_DELIVER=2000000
# GAS_CANCEL=2000000
# RELAY_POLL_MS=8000               # deliver/cancel worker poll interval
#
# --- Optional /relay/withdrawToCore (shielded withdraw straight to a HyperCore
#     spot address the user need not control). Disabled until the key is set. ---
# HL_SPOT_BRIDGE_PRIVATE_KEY=0x... # dedicated transit wallet, funded with HYPE.
#                                  # Funds unshield TO it, it bridges to Core and
#                                  # spotSends to the destination. Jobs are
#                                  # serialized; expose its address via /relay/info.
# GAS_BRIDGE_TRANSFER=300000       # bridge-wallet ERC20 transfer to system addr
# GAS_BRIDGE_SPOTSEND=2000000      # bridge-wallet CoreWriter spotSend
# BRIDGE_CREDIT_POLL_MS=3000       # poll interval waiting for Core to credit
# BRIDGE_CREDIT_POLL_TRIES=25      # ~75s total before giving up (bridge_pending)
# SPOT_RESUME_MS=30000             # resume worker cadence for unfinished jobs
# SPOT_MAX_ATTEMPTS=3              # park a stuck job as 'failed' after N tries
# CORE_DEPOSIT_WALLET=0x6b9e773128f453f5c2c60935ee2de2cbc5390a24  # USDC (coreToken 0)
#   bridges EVM->Core via Circle's CoreDepositWallet (approve + deposit), NOT the
#   0x2000+idx system-address transfer. Defaults to the mainnet address on chain 999.
