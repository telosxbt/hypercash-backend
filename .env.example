# HyperEVM JSON-RPC (eth_getLogs capped at 1000-block range)
RPC_URL=https://hyperliquid-testnet.g.alchemy.com/v2/XXXX
# Postgres (Railway provides DATABASE_URL automatically when you attach a PG plugin)
DATABASE_URL=postgres://user:pass@host:5432/railway
# Pools to index: JSON array of { address, deployBlock, label }
POOLS=[{"address":"0xfb81337d6d1b5bb43428c7bcf4774bd833807d7f","deployBlock":56390000,"label":"usdc"}]
# Tuning
CONFIRMATIONS=5
POLL_INTERVAL_MS=4000
LOG_CHUNK=999
BACKFILL_CONCURRENCY=10
PORT=3000
CORS_ORIGIN=*
# Tests only: a throwaway Postgres for `bun test`
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5544/postgres

# --- Optional v1 relayer (/relay/*) — only enabled if RELAYER_PRIVATE_KEY set ---
# RELAYER_PRIVATE_KEY=0x...        # funded with HYPE for gas (signs trade + deliver/cancel)
# CHAIN_ID=998
# TRADER_ADDRESS=0x...
# USDC_POOL_ADDRESS=0x...
# HYPE_POOL_ADDRESS=0x...
# CORE_GATEWAY=0x...               # optional; else read via trader.core() (spotBalance)
# MIN_FEE_USDC=0                   # must cover gas of trade() + deliver()/cancel()
# MIN_FEE_HYPE=0
# GAS_TRADE=2500000
# GAS_DELIVER=2000000
# GAS_CANCEL=2000000
# RELAY_POLL_MS=8000               # deliver/cancel worker poll interval
